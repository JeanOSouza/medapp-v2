{
  "expo": {
    "name": "MedApp",
    "slug": "medapp",
    "version": "1.0.1",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./src/assets/icon.png",
    "assetBundlePatterns": ["**/*", "src/assets/**/*"],
    "plugins": [
      [
        "expo-notifications",
        {
          "sounds": ["./assets/sounds/notification_sound.wav"]
        }
      ]
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.anonymous.medapp",
      "buildNumber": "2",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.anonymous.medapp",
      "versionCode": 2,
      "permissions": [
        "USE_EXACT_ALARM",
        "SCHEDULE_EXACT_ALARM",
        "RECEIVE_BOOT_COMPLETED"
      ]
    },
    "extra": {
      "eas": {
        "projectId": "c9acec30-f7c5-4131-819b-2f405a5fa83c"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/c9acec30-f7c5-4131-819b-2f405a5fa83c"
    },
    "owner": "itsjeansouz"
  }
}
